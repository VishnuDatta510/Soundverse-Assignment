DATABASE_URL=your-database-url

API_KEY=change-me-to-a-strong-secret

APP_NAME=SoundVerse

# If Postgres fails with "could not translate host name" (offline, DNS, VPN), set to 1
FORCE_SQLITE_LOCAL=0

# If Supabase/Postgres is unreachable (DNS, offline), app auto-switches to ./soundverse.db (default: true)
AUTO_SQLITE_FALLBACK=true
